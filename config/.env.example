# ===== AI Media Factory 配置模板 =====
# 复制本文件为 .env，填入你自己的密钥

# 智谱 AI (GLM-4-flash 文案生成 + CogView 图片生成)
# 免费: https://open.bigmodel.cn/
ZHIPUAI_API_KEY=

# 火山引擎语音合成大模型 (预设音色 TTS)
# https://console.volcengine.com/speech/service/8
VOLC_TTS_APPID=
VOLC_TTS_TOKEN=
VOLC_TTS_CLUSTER=volcano_tts

# 火山引擎声音复刻 (克隆音色合成 - 可选, 不填则用预设音色)
# 需先在控制台训练出 S_xxxxx 音色
VOLC_CLONE_APPID=
VOLC_CLONE_TOKEN=
VOLC_CLONE_SPEAKER=

# MiniMax 图片生成 (海螺图像, 推荐 - 质量最高)
# https://platform.minimaxi.com/
MINIMAX_API_KEY=

# 通义千问 DashScope (可选)
DASHSCOPE_API_KEY=
